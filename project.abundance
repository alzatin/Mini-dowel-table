            },
            {
              "atomType": "Code",
              "x": 0.7310513447432763,
              "y": 0.35670731707317077,
              "uniqueID": "id-7132",
              "ioValues": [
                {
                  "name": "geometry",
                  "ioValue": "__GEOMETRY_INPUT__"
                }
              ],
              "codeVersion": 1,
              "code": "const Inputs = [\n  { inputName: \"geometry\", type: \"geometry\", defaultValue: null }\n];\n\nlet importedGeometry = library[geometry];\n\n// Test multiple rotations to find the flattest orientation\nconst rotations = [\n  [0, 0, 0],\n  [90, 0, 0],\n  [0, 90, 0],\n  [0, 0, 90],\n  [45, 45, 0],\n  [90, 45, 0],\n  [0, 90, 45]\n];\n\nlet bestRotation = [0, 0, 0];\nlet minHeight = Infinity;\n\nfor (const [rotX, rotY, rotZ] of rotations) {\n  let rotated = await Rotate(importedGeometry, rotX, rotY, rotZ);\n  let bounds = await GetBounds(rotated);\n  let height = bounds.max[2] - bounds.min[2];\n  \n  if (height < minHeight) {\n    minHeight = height;\n    bestRotation = [rotX, rotY, rotZ];\n  }\n}\n\n// Apply the best rotation\nlet flatGeometry = await Rotate(importedGeometry, bestRotation[0], bestRotation[1], bestRotation[2]);\n\n// Move to XY plane\nlet bounds = await GetBounds(flatGeometry);\nlet zOffset = -bounds.min[2];\nlet flatOnXY = await Move(flatGeometry, 0, 0, zOffset);\n\nlet result = {\n  geometry: [flatOnXY],\n  dimension: \"3D\",\n  tags: [\"autoFlattened\"],\n  color: \"#A3CE5B\",\n  plane: new replicad.Plane(),\n  bom: []\n};\n\nreturn result;"
            },
            {
              "atomType": "Code",
              "x": 0.6291768541157294,
              "y": 0.673780487804878,
              "uniqueID": "id-7133",
              "ioValues": [
                {
                  "name": "geometry",
                  "ioValue": "__GEOMETRY_INPUT__"
                }
              ],
              "codeVersion": 1,
              "code": "const Inputs = [\n  { inputName: \"geometry\", type: \"geometry\", defaultValue: null }\n];\n\nlet importedGeometry = library[geometry];\n\n// Test multiple rotations to find the flattest orientation\nconst rotations = [\n  [0, 0, 0],\n  [90, 0, 0],\n  [0, 90, 0],\n  [0, 0, 90],\n  [45, 45, 0],\n  [90, 45, 0],\n  [0, 90, 45]\n];\n\nlet bestRotation = [0, 0, 0];\nlet minHeight = Infinity;\n\nfor (const [rotX, rotY, rotZ] of rotations) {\n  let rotated = await Rotate(importedGeometry, rotX, rotY, rotZ);\n  let bounds = await GetBounds(rotated);\n  let height = bounds.max[2] - bounds.min[2];\n  \n  if (height < minHeight) {\n    minHeight = height;\n    bestRotation = [rotX, rotY, rotZ];\n  }\n}\n\n// Apply the best rotation\nlet flatGeometry = await Rotate(importedGeometry, bestRotation[0], bestRotation[1], bestRotation[2]);\n\n// Move to XY plane\nlet bounds = await GetBounds(flatGeometry);\nlet zOffset = -bounds.min[2];\nlet flatOnXY = await Move(flatGeometry, 0, 0, zOffset);\n\nlet result = {\n  geometry: [flatOnXY],\n  dimension: \"3D\",\n  tags: [\"autoFlattened\"],\n  color: \"#A3CE5B\",\n  plane: new replicad.Plane(),\n  bom: []\n};\n\nreturn result;"
            }
          ],
