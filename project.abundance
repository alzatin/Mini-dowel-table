                          "name": "diameter",
                          "ioValue": 10
                        }
                      ]
                    },
                    {
                      "atomType": "Extrude",
                      "x": 0.4154362416107382,
                      "y": 0.2546583850931677,
                      "uniqueID": "id-2418",
                      "ioValues": [
